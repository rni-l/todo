#!/usr/bin/env bash
set -euo pipefail

APP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
GRADLE_VERSION="8.13"
GRADLE_HOME="${APP_DIR}/.gradle/bootstrap/gradle-${GRADLE_VERSION}"
GRADLE_BIN="${GRADLE_HOME}/bin/gradle"
DIST_URL="https://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-bin.zip"
DIST_ZIP="${APP_DIR}/.gradle/bootstrap/gradle-${GRADLE_VERSION}-bin.zip"

if [[ ! -x "${GRADLE_BIN}" ]]; then
  mkdir -p "${APP_DIR}/.gradle/bootstrap"
  if [[ ! -f "${DIST_ZIP}" ]]; then
    echo "Downloading Gradle ${GRADLE_VERSION}..."
    curl -fsSL "${DIST_URL}" -o "${DIST_ZIP}"
  fi
  unzip -q -o "${DIST_ZIP}" -d "${APP_DIR}/.gradle/bootstrap"
fi

exec "${GRADLE_BIN}" "$@"
