{
  "name": "personal-todo-self-hosted",
  "version": "1.7.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node server.js",
    "dev:client": "vite --host 127.0.0.1",
    "start": "node server.js",
    "build:client": "vite build",
    "release:build": "npm run build:client && node scripts/package-release.mjs",
    "pm2:start": "pm2 start ecosystem.config.cjs --only personal-todo",
    "pm2:restart": "pm2 startOrReload ecosystem.config.cjs --only personal-todo --update-env",
    "pm2:stop": "pm2 stop personal-todo",
    "pm2:logs": "pm2 logs personal-todo",
    "test": "node --experimental-strip-types --test tests/*.test.js tests/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  }
}
